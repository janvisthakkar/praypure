/* Coming Soon Banner */
.coming-soon-container {
    width: 100%;
    margin-top: var(--spacing-lg);
}

.coming-soon-banner {
    background: var(--color-white);
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    min-height: 480px;
    position: relative;
    box-shadow: 0 15px 45px rgba(62, 39, 35, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.15);
}

.coming-soon-content {
    flex: 1;
    padding: 60px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 2;
    background: var(--color-white);
}

.coming-soon-badge {
    display: inline-block;
    color: var(--color-golden);
    background: rgba(212, 175, 55, 0.1);
    padding: 6px 16px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
    width: fit-content;
}

.coming-soon-content h2 {
    font-family: var(--font-serif);
    font-size: 42px;
    color: var(--color-dark-brown);
    margin-bottom: 15px;
    line-height: 1.2;
}

.coming-soon-content p {
    font-size: 18px;
    color: var(--color-light-brown);
    line-height: 1.6;
    margin-bottom: 30px;
    max-width: 600px;
}

.stay-tuned {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 30px;
    color: var(--color-dark-brown);
    font-weight: 500;
}

.pulse-dot {
    width: 10px;
    height: 10px;
    background-color: var(--color-golden);
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.7);
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(212, 175, 55, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(212, 175, 55, 0); }
}

.coming-soon-decor {
    width: 40%;
    background: linear-gradient(135deg, var(--color-cream) 0%, rgba(212, 175, 55, 0.1) 100%);
    position: relative;
    overflow: hidden;
}

.decor-circle {
    position: absolute;
    border-radius: 50%;
    background: var(--color-golden);
    opacity: 0.1;
}

.circle-1 { width: 300px; height: 300px; top: -50px; right: -50px; }
.circle-2 { width: 200px; height: 200px; bottom: 20px; left: -20px; }

@media (max-width: 900px) {
    .coming-soon-banner { flex-direction: column; min-height: auto; }
    .coming-soon-decor { width: 100%; height: 150px; order: -1; }
    .coming-soon-content { padding: 40px; text-align: center; align-items: center; }
    .coming-soon-content h2 { font-size: 32px; }
}
